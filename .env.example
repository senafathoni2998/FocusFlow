# Database
DATABASE_URL="postgresql://user:password@localhost:5432/focusflow_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# ---- AI providers ----
# The assistant + insights work with any of these providers (all OpenAI-SDK
# compatible). Add a key for each provider you want to use; pick the active one
# from the in-app Settings page. AI_PROVIDER sets the default when a user hasn't
# chosen one (defaults to "groq"). Optional *_MODEL vars override the model.

# Default provider: groq | openai | anthropic | deepseek | gemini
AI_PROVIDER="groq"

# Groq (Llama) - https://console.groq.com/
GROQ_API_KEY="your-groq-api-key-here"
# GROQ_MODEL="llama-3.3-70b-versatile"

# OpenAI (GPT) - https://platform.openai.com/api-keys
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# Claude (Anthropic) - https://console.anthropic.com/
# ANTHROPIC_API_KEY="sk-ant-..."
# ANTHROPIC_MODEL="claude-3-5-haiku-latest"

# DeepSeek - https://platform.deepseek.com/
# DEEPSEEK_API_KEY="..."
# DEEPSEEK_MODEL="deepseek-chat"

# Gemini (Google) - https://aistudio.google.com/apikey
# GEMINI_API_KEY="..."
# GEMINI_MODEL="gemini-2.0-flash"
