generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  // Preferred AI provider for the assistant/insights (groq|openai|anthropic|
  // deepseek|gemini). Null = fall back to the AI_PROVIDER env / groq default.
  aiProvider String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks      Task[]
  sessions   FocusSession[]
  lists      List[]
  tags       Tag[]
  recurrenceRules RecurrenceRule[]
  habits     Habit[]
  goals      Goal[]
  reminders  Reminder[]
  savedFilters SavedFilter[]
}

model Habit {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  icon          String   @default("✅")
  color         String   @default("primary") // tailwind palette key: primary|success|warning|danger
  frequencyType String   @default("daily") // daily | weekly
  weekdays      Int[]    @default([]) // 0-6 (Sun-Sat); empty = every day (daily)
  weeklyTarget  Int      @default(1) // times per week (weekly)
  goalType      String   @default("achieve") // achieve | amount
  targetAmount  Float?   @default(1)
  unit          String?
  archived      Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  checkIns HabitCheckIn[]

  @@index([userId, archived])
}

model HabitCheckIn {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  amount    Float    @default(1)
  createdAt DateTime @default(now())

  @@unique([habitId, date])
}

model Goal {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title          String
  description    String?   @db.Text
  icon           String    @default("🎯")
  color          String    @default("primary") // tailwind palette key: primary|success|warning|danger
  progressType   String    @default("manual") // manual | numeric
  targetValue    Float? // numeric: the target to reach
  currentValue   Float     @default(0) // numeric: progress so far
  unit           String? // numeric: e.g. "books"
  manualProgress Int       @default(0) // manual: 0-100
  targetDate     DateTime? // optional deadline (stored UTC-midnight, keyed by calendar day)
  status         String    @default("active") // active | achieved | archived
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tasks Task[]

  @@index([userId, status])
}

model Reminder {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId       String
  task         Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  triggerAt    DateTime // absolute instant the reminder should fire
  dispatchedAt DateTime? // set once a dispatcher has surfaced it (store-only: unused for now)
  createdAt    DateTime  @default(now())

  @@index([userId, triggerAt])
  @@index([taskId])
}

model RecurrenceRule {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  freq           String    // daily | weekly | monthly | yearly
  interval       Int       @default(1)
  byWeekday      Int[]     @default([]) // 0-6 (Sun-Sat), weekly only
  anchorMode     String    @default("due") // due | completion
  until          DateTime?
  count          Int?
  completedCount Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  task Task?

  @@index([userId])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks TaskTag[]

  @@unique([userId, name])
  @@index([userId])
}

model TaskTag {
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

model List {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  @@index([userId])
}

model SavedFilter {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  // The canonical URL search string of the saved view (e.g.
  // "horizon=thisMonth&priority=high&sort=priority"), whitelisted to known keys.
  query     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  status      String   @default("todo") // todo, in-progress, completed, wont-do
  priority    String   @default("medium") // none, low, medium, high
  dueDate     DateTime?
  order       Int      @default(0)

  // Phase 1 additions
  startDate       DateTime?
  isAllDay        Boolean   @default(true)
  completedAt     DateTime?
  timeEstimateMin Int?
  estimatedPomos  Int?
  priorityRank    Int       @default(2) // none=0, low=1, medium=2, high=3 (sort key)

  // Subtasks: self-relation. Deleting a parent cascades to its subtasks.
  parentTaskId String?
  parentTask   Task?   @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks     Task[]  @relation("Subtasks")

  // List container. Null listId = Inbox. Deleting a list re-parents its tasks
  // to Inbox (SetNull) rather than deleting them.
  listId String?
  list   List?   @relation(fields: [listId], references: [id], onDelete: SetNull)

  // Tags (many-to-many via the TaskTag join table).
  tags TaskTag[]

  // Recurrence (1-1). On completion a recurring task rolls the same row forward
  // to its next occurrence. Deleting the rule clears the link (SetNull).
  recurrenceId String?         @unique
  recurrence   RecurrenceRule? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)

  // Goal this task contributes to. Deleting a goal keeps the task (SetNull); a
  // "tasks"-progress goal derives its percent from its linked tasks.
  goalId String?
  goal   Goal?   @relation(fields: [goalId], references: [id], onDelete: SetNull)

  // Reminders (store-only): absolute trigger times a future dispatcher consumes.
  reminders Reminder[]

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions FocusSession[]

  @@index([userId, dueDate])
  @@index([userId, status, dueDate])
  @@index([userId, priorityRank])
  @@index([parentTaskId])
  @@index([userId, listId])
  @@index([goalId])
}

model FocusSession {
  id          String   @id @default(cuid())
  type        String   @default("pomodoro") // pomodoro, short-break, long-break
  duration    Int      // in seconds
  status      String   @default("completed") // running, completed, cancelled
  startTime   DateTime
  endTime     DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([userId, startTime])
}
