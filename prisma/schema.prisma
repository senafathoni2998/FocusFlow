generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks      Task[]
  sessions   FocusSession[]
  lists      List[]
  tags       Tag[]
  recurrenceRules RecurrenceRule[]
}

model RecurrenceRule {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  freq           String    // daily | weekly | monthly | yearly
  interval       Int       @default(1)
  byWeekday      Int[]     @default([]) // 0-6 (Sun-Sat), weekly only
  anchorMode     String    @default("due") // due | completion
  until          DateTime?
  count          Int?
  completedCount Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  task Task?

  @@index([userId])
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks TaskTag[]

  @@unique([userId, name])
  @@index([userId])
}

model TaskTag {
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@index([tagId])
}

model List {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks Task[]

  @@index([userId])
}

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  status      String   @default("todo") // todo, in-progress, completed, wont-do
  priority    String   @default("medium") // none, low, medium, high
  dueDate     DateTime?
  order       Int      @default(0)

  // Phase 1 additions
  startDate       DateTime?
  isAllDay        Boolean   @default(true)
  completedAt     DateTime?
  timeEstimateMin Int?
  estimatedPomos  Int?
  priorityRank    Int       @default(2) // none=0, low=1, medium=2, high=3 (sort key)

  // Subtasks: self-relation. Deleting a parent cascades to its subtasks.
  parentTaskId String?
  parentTask   Task?   @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks     Task[]  @relation("Subtasks")

  // List container. Null listId = Inbox. Deleting a list re-parents its tasks
  // to Inbox (SetNull) rather than deleting them.
  listId String?
  list   List?   @relation(fields: [listId], references: [id], onDelete: SetNull)

  // Tags (many-to-many via the TaskTag join table).
  tags TaskTag[]

  // Recurrence (1-1). On completion a recurring task rolls the same row forward
  // to its next occurrence. Deleting the rule clears the link (SetNull).
  recurrenceId String?         @unique
  recurrence   RecurrenceRule? @relation(fields: [recurrenceId], references: [id], onDelete: SetNull)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions FocusSession[]

  @@index([userId, dueDate])
  @@index([userId, status, dueDate])
  @@index([userId, priorityRank])
  @@index([parentTaskId])
  @@index([userId, listId])
}

model FocusSession {
  id          String   @id @default(cuid())
  type        String   @default("pomodoro") // pomodoro, short-break, long-break
  duration    Int      // in seconds
  status      String   @default("completed") // running, completed, cancelled
  startTime   DateTime
  endTime     DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())

  @@index([userId, startTime])
}
